# Server-only secret. Never prefix this variable with VITE_ or WXT_.
DEEPL_API_KEY=replace-with-your-deepl-api-key

# API Pro uses https://api.deepl.com/v2.
DEEPL_API_BASE_URL=https://api-free.deepl.com/v2

TRANSLATION_SERVER_HOST=127.0.0.1
TRANSLATION_SERVER_PORT=8787

# Production reverse proxies must overwrite X-Forwarded-For before enabling this.
TRUST_PROXY=false

# Required in production for Chrome. Comma-separated Chrome Web Store IDs.
ALLOWED_CHROME_EXTENSION_IDS=

# Optional tuning (defaults shown).
MAX_REQUEST_BYTES=32768
MAX_TEXT_CHARACTERS=10000
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_MS=60000
DAILY_CHARACTER_LIMIT=40000
GLOBAL_DAILY_CHARACTER_LIMIT=250000
# Per-request technical logs are opt-in. Aggregate budget metrics contain no text.
LOG_REQUEST_METRICS=false
LOG_USAGE_METRICS=true
# Exact client addresses to reject, comma-separated. Never add translated text.
BLOCKED_CLIENT_ADDRESSES=
DEEPL_QUOTA_STOP_RATIO=0.95
DEEPL_USAGE_REFRESH_MS=300000
DEEPL_MAX_RETRIES=2
DEEPL_RETRY_MAX_DELAY_MS=5000
