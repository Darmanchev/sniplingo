# Server-only secret. Never prefix this variable with VITE_ or WXT_.
DEEPL_API_KEY=replace-with-your-deepl-api-key

# DeepL API Free endpoint. API Pro uses https://api.deepl.com/v2/translate.
DEEPL_API_URL=https://api-free.deepl.com/v2/translate

TRANSLATION_SERVER_HOST=127.0.0.1
TRANSLATION_SERVER_PORT=8787

# Public URL embedded into the extension build. It is not a secret.
WXT_TRANSLATION_API_URL=http://127.0.0.1:8787/v1/translate
