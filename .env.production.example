# Server-only secret. Never prefix it with WXT_ or expose it to the extension.
DEEPL_API_KEY=replace-with-your-deepl-api-key

NODE_ENV=production
TRANSLATION_SERVER_HOST=0.0.0.0
TRANSLATION_SERVER_PORT=8787

# Comma-separated IDs accepted by the production API. Use the ID assigned to
# the published Chrome extension (and add a stable development ID if needed).
ALLOWED_CHROME_EXTENSION_IDS=replace-with-your-chrome-extension-id
ALLOW_ANY_CHROME_EXTENSION=false
ALLOW_MISSING_ORIGIN=false

# Caddy/Nginx on the same VPS is the only trusted proxy.
TRUST_PROXY=true

MAX_REQUEST_BYTES=32768
MAX_TEXT_CHARACTERS=10000
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_MS=60000
DAILY_CHARACTER_LIMIT=40000
GLOBAL_DAILY_CHARACTER_LIMIT=250000
DEEPL_QUOTA_STOP_RATIO=0.95
LOG_REQUEST_METRICS=false
LOG_USAGE_METRICS=true

# Public value embedded into production extension packages.
WXT_TRANSLATION_API_URL=https://api.sniplingo.example/v1/translate
